{
  "name": "brainspark",
  "version": "0.1.0",
  "description": "AI-powered brainstorming assistant with mind map visualization",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.51.0",
    "@dagrejs/dagre": "^3.0.0",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "docx": "^9.5.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.513.0",
    "openai": "^4.103.0",
    "reactflow": "^11.11.4",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.brainspark.app",
    "productName": "BrainSpark",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
